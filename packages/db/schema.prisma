model GstrFiling {
  id         String       @id @default(cuid())
  clientId   String
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  returnType ReturnType
  period     String
  status     FilingStatus @default(NOT_STARTED)
  arn        String?
  filedOn    DateTime?
  jsonPath   String?
  validation Json?
  @@unique([clientId, returnType, period])
}

model Gstr2bImport {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period     String
  source     String
  rawJson    Json
  importedAt DateTime @default(now())
  @@unique([clientId, period])
}

model ReconRun {
  id        String      @id @default(cuid())
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period    String
  config    Json
  stats     Json
  createdAt DateTime    @default(now())
  lines     ReconLine[]
}

model ReconLine {
  id              String           @id @default(cuid())
  reconRunId      String
  reconRun        ReconRun         @relation(fields: [reconRunId], references: [id], onDelete: Cascade)
  bucket          ReconMatchBucket
  confidence      Float?
  booksPurchaseId String?
  booksGstin      String?
  booksInvNo      String?
  booksDate       DateTime?        @db.Date
  booksTaxable    Decimal?         @db.Decimal(18, 2)
  booksItc        Decimal?         @db.Decimal(18, 2)
  g2bSection      String?
  g2bGstin        String?
  g2bInvNo        String?
  g2bDate         DateTime?        @db.Date
  g2bTaxable      Decimal?         @db.Decimal(18, 2)
  g2bItc          Decimal?         @db.Decimal(18, 2)
  imsStatus       ImsAction        @default(NONE)
  variance        Decimal?         @db.Decimal(18, 2)
  matchReason     String?
  @@index([reconRunId, bucket])
}

model ReconToleranceConfig {
  id             String  @id @default(cuid())
  tenantId       String  @unique
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dateDays       Int     @default(3)
  valuePct       Float   @default(0.5)
  taxAbs         Decimal @db.Decimal(18, 2) @default(1)
  invNoNormalize Boolean @default(true)
  fuzzyEnabled   Boolean @default(true)
}

model EInvoice {
  id          String         @id @default(cuid())
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceId   String         @unique
  invoice     Invoice        @relation(fields: [invoiceId], references: [id])
  irn         String?
  ackNo       String?
  ackDate     DateTime?
  signedQr    String?
  status      EInvoiceStatus @default(PENDING)
  errorMsg    String?
  generatedAt DateTime?
}

model EwayBill {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  docType     String
  docNo       String
  ewbNo       String?
  validUntil  DateTime?
  distance    Int?
  vehicleNo   String?
  status      String   @default("draft")
  payload     Json?
  createdAt   DateTime @default(now())
}

model ImsRecord {
  id            String    @id @default(cuid())
  clientId      String
  period        String
  supplierGstin String    @db.Char(15)
  invoiceNo     String
  invoiceDate   DateTime  @db.Date
  taxable       Decimal   @db.Decimal(18, 2)
  itc           Decimal   @db.Decimal(18, 2)
  action        ImsAction @default(PENDING)
  actionDate    DateTime?
  purchaseId    String?

  @@index([clientId, period])
}

model ItcLedger {
  id          String   @id @default(cuid())
  clientId    String
  period      String
  opening     Decimal  @db.Decimal(18, 2) @default(0)
  availed     Decimal  @db.Decimal(18, 2) @default(0)
  reversed    Decimal  @db.Decimal(18, 2) @default(0)
  closing     Decimal  @db.Decimal(18, 2) @default(0)

  @@unique([clientId, period])
}

