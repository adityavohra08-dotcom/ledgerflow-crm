model Retainer {
  id          String   @id @default(cuid())
  tenantId    String
  clientId    String
  contactId   String?
  name        String
  amount      Decimal  @db.Decimal(18, 2)
  frequency   String
  nextInvoice DateTime @db.Date
  isActive    Boolean  @default(true)
}

// =============================================================================
// AUTOMATION & WORKFLOWS
// =============================================================================

model AutomationRule {
  id        String          @id @default(cuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  trigger   WorkflowTrigger
  entity    String
  conditions Json
  actions   Json
  isActive  Boolean         @default(true)
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  tenantId    String
  clientId    String
  entityType  String
  entityId    String
  requestedBy String
  requester   User           @relation("ApprovalRequester", fields: [requestedBy], references: [id])
  status      ApprovalStatus @default(PENDING)
  actedBy     String?
  actor       User?          @relation("ApprovalActor", fields: [actedBy], references: [id])
  actedAt     DateTime?
  notes       String?
  createdAt   DateTime       @default(now())

  @@index([clientId, status])
}

// =============================================================================
// DOCUMENTS, COMMENTS, CUSTOM FIELDS
// =============================================================================

model DocumentAttachment {
  id         String   @id @default(cuid())
  tenantId   String
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageUrl String
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model Comment {
  id         String   @id @default(cuid())
  tenantId   String
  entityType String
  entityId   String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  body       String
  mentions   String[] @default([])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model CustomFieldDef {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType String
  name       String
  fieldType  String   // text, number, date, dropdown
  options    String[] @default([])
  isRequired Boolean  @default(false)
  values     CustomFieldValue[]

  @@unique([tenantId, entityType, name])
}

model CustomFieldValue {
  id        String         @id @default(cuid())
  fieldId   String
  field     CustomFieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  entityId  String
  value     String

  @@unique([fieldId, entityId])
}

// =============================================================================
// REPORTING & AUDIT
// =============================================================================

model ReportSnapshot {
  id         String   @id @default(cuid())
  tenantId   String
  clientId   String
  reportType String   // PNL, BALANCE_SHEET, TRIAL_BALANCE, AGING_AR
  period     String
  data       Json
  createdAt  DateTime @default(now())

  @@index([clientId, reportType, period])
}

model ScheduledReport {
  id         String   @id @default(cuid())
  tenantId   String
  clientId   String
  reportType String
  frequency  String
  recipients String[]
  nextRun    DateTime @db.Date
  isActive   Boolean  @default(true)
}

model DashboardWidget {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  widget   String
  config   Json
  position Int    @default(0)
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  clientId  String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([clientId, entity])
