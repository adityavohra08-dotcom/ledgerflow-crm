// =============================================================================
// CURRENCY (MULTI-CURRENCY READY)
// =============================================================================

model Currency {
  code      String   @id @db.Char(3)
  name      String
  symbol    String
  isActive  Boolean  @default(true)
  ratesFrom ExchangeRate[] @relation("BaseCurrency")
  ratesTo   ExchangeRate[] @relation("QuoteCurrency")
}

model ExchangeRate {
  id             String   @id @default(cuid())
  baseCurrency   String   @db.Char(3)
  base           Currency @relation("BaseCurrency", fields: [baseCurrency], references: [code])
  quoteCurrency  String   @db.Char(3)
  quote          Currency @relation("QuoteCurrency", fields: [quoteCurrency], references: [code])
  rate           Decimal  @db.Decimal(18, 8)
  effectiveDate  DateTime @db.Date

  @@unique([baseCurrency, quoteCurrency, effectiveDate])
}