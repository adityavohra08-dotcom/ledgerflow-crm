# Copy to .env and adjust
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-in-production
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,file://
DB_PATH=./data/store.json
DEFAULT_TENANT_ID=udyog-suvidha
# Subdomain tenant routing: acme.ledgerflow.app → tenant acme (comma-separated suffixes)
TENANT_HOST_SUFFIXES=ledgerflow.app,ledgerflow.in
# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3001, https://your-domain.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Demo Google buttons when GOOGLE_CLIENT_ID is empty (local dev). Set false in production.
GOOGLE_DEMO=true

# Optional — real SMS OTP (without these, OTP is shown in demo mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firewall / rate limiting (enabled by default; set FIREWALL_ENABLED=false to disable)
FIREWALL_ENABLED=true
FIREWALL_BLOCK_IPS=
RATE_LIMIT_AUTH_MAX=15
RATE_LIMIT_OTP_SEND_MAX=5
RATE_LIMIT_API_MAX=300
FIREWALL_AUTO_BLOCK_THRESHOLD=25

# E-Way Bill provider: demo | portal | sandbox | mastergst
EWAYBILL_PROVIDER=sandbox

# Portal API user (all live providers) — ewaybillgst.gov.in → Registration → For GSP
EWAYBILL_GSTIN=29AAACQ3770E000
EWAYBILL_USERNAME=your_portal_api_username
EWAYBILL_PASSWORD=your_portal_api_password

# Sandbox.co.in (FREE alternate — developer.sandbox.co.in)
EWAYBILL_API_KEY=key_test_xxx
EWAYBILL_API_SECRET=secret_test_xxx
EWAYBILL_SANDBOX_ENV=test

# MasterGST (alternate GSP — app.mastergst.com)
EWAYBILL_CLIENT_ID=
EWAYBILL_CLIENT_SECRET=
EWAYBILL_EMAIL=
EWAYBILL_IP_ADDRESS=
EWAYBILL_API_URL=https://api.mastergst.com/ewaybillapi/v1.03