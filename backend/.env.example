# Copy to .env and adjust
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-in-production
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,file://
DB_PATH=./data/store.json
DEFAULT_TENANT_ID=udyog-suvidha
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional — real SMS OTP (without these, OTP is shown in demo mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firewall / rate limiting (enabled by default; set FIREWALL_ENABLED=false to disable)
FIREWALL_ENABLED=true
FIREWALL_BLOCK_IPS=
RATE_LIMIT_AUTH_MAX=15
RATE_LIMIT_OTP_SEND_MAX=5
RATE_LIMIT_API_MAX=300
FIREWALL_AUTO_BLOCK_THRESHOLD=25

# Live E-Way Bill (demo mode when any required var is missing)
# Step 1: MasterGST developer account → Credentials → E-Way Bill → Client ID + Secret
# Step 2: ewaybillgst.gov.in → Registration → For GSP → register MasterGST/Tera Software → API user + password
EWAYBILL_PROVIDER=mastergst
EWAYBILL_GSTIN=09XXXXXXXXXX1ZX
EWAYBILL_USERNAME=your_portal_api_username
EWAYBILL_PASSWORD=your_portal_api_password
EWAYBILL_CLIENT_ID=your_mastergst_client_id
EWAYBILL_CLIENT_SECRET=your_mastergst_client_secret
EWAYBILL_EMAIL=
EWAYBILL_IP_ADDRESS=
EWAYBILL_API_URL=https://api.mastergst.com/ewaybillapi/v1.03